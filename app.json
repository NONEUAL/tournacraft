{
  "expo": {
    "name": "Tournacraft",
    "slug": "tournacraft",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "tournacraft",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1E1E2E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourorg.tournacraft"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E1E2E"
      },
      "package": "com.yourorg.tournacraft"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
